# Executive Agent Backend — Environment Variables Template
# Copy this file to ".env" and fill in your real values.

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Obtain your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ─── CORS (comma separated origins for the Flutter app in development) ────────
CORS_ORIGINS=http://localhost,http://localhost:8080,http://127.0.0.1

# ─── Google OAuth 2.0 ────────────────────────────────────────────────────────
# 1. Go to: https://console.cloud.google.com/
# 2. Create a project → Enable Gmail API & Google Calendar API
# 3. Go to Credentials → Create OAuth 2.0 Client ID → Web application
# 4. Add Authorized redirect URI: http://localhost:8000/auth/google/callback
# 5. Copy Client ID and Client Secret below
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ─── Supabase ─────────────────────────────────────────────────────────────────
# 1. Create a free project at: https://supabase.com
# 2. Go to Project Settings → API
# 3. Copy the Project URL and anon/public key
# 4. IMPORTANT: Also create the user_credentials table (see README for SQL)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Development ──────────────────────────────────────────────────────────────
# Dev user UUID — used as a placeholder until real auth is added in M4
# You can keep this default or generate your own UUID
DEV_USER_ID=00000000-0000-0000-0000-000000000001
